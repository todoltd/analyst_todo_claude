    <!-- ===================== td.bi.dashboard.state ======================== -->

    <!-- AC-16 — td.bi.dashboard.state (особиста закладка/стан):
         CUD ЛИШЕ власнику запису (user_id = user.id). Авторські СПІЛЬНІ стани
         (user_id порожній — personal_default дашборда, виставлений дизайнером)
         доступні УСІМ на ЧИТАННЯ, але користувач не може їх змінювати/видаляти
         (write/create/unlink — лише на своїх записах). Тому read-предикат
         ширший за write/create/unlink: розділяємо на два правила. -->
    <record id="rule_dashboard_state_read" model="ir.rule">
        <field name="name">BI Стан/закладка: read власних + авторських спільних</field>
        <field name="model_id" ref="model_td_bi_dashboard_state"/>
        <field name="domain_force">[
            '|',
                ('user_id', '=', user.id),
                ('user_id', '=', False),
        ]</field>
        <field name="groups" eval="[(4, ref('td_bi_dashboard.group_bi_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
