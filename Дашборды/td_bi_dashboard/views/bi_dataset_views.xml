<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.measure — проста list+form (вкладена + standalone)          -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_measure_list" model="ir.ui.view">
        <field name="name">td.bi.measure.list</field>
        <field name="model">td.bi.measure</field>
        <field name="arch" type="xml">
            <list string="Міри">
                <field name="name"/>
                <field name="field_id"/>
                <field name="aggregator"/>
                <field name="show_as"/>
                <field name="time_intelligence"/>
            </list>
        </field>
    </record>

    <record id="view_bi_measure_form" model="ir.ui.view">
        <field name="name">td.bi.measure.form</field>
        <field name="model">td.bi.measure</field>
        <field name="arch" type="xml">
            <form string="Міра">
                <sheet>
                    <group>
                        <group>
                            <field name="dataset_id"/>
                            <field name="name"/>
                            <field name="field_id"/>
                            <field name="aggregator"/>
                            <field name="expression"/>
                            <field name="extra_domain"/>
                        </group>
                        <group>
                            <field name="show_as"/>
                            <field name="time_intelligence"/>
                            <field name="rolling_n" invisible="time_intelligence != 'rolling'"/>
                            <field name="comparison"/>
                            <field name="format_spec"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.parameter — проста list+form (вкладена + standalone)        -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_parameter_list" model="ir.ui.view">
        <field name="name">td.bi.parameter.list</field>
        <field name="model">td.bi.parameter</field>
        <field name="arch" type="xml">
            <list string="Параметри">
                <field name="name"/>
                <field name="label"/>
                <field name="param_type"/>
                <field name="permitted"/>
                <field name="url_changeable"/>
            </list>
        </field>
    </record>

    <record id="view_bi_parameter_form" model="ir.ui.view">
        <field name="name">td.bi.parameter.form</field>
        <field name="model">td.bi.parameter</field>
        <field name="arch" type="xml">
            <form string="Параметр">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="label"/>
                            <field name="dataset_id"/>
                            <field name="dashboard_id"/>
                            <field name="param_type"/>
                            <field name="url_changeable"/>
                        </group>
                        <group>
                            <field name="permitted"/>
                            <field name="selection_values" invisible="permitted != 'list'"/>
                            <field name="min" invisible="param_type != 'number'"/>
                            <field name="max" invisible="param_type != 'number'"/>
                            <field name="step" invisible="param_type != 'number'"/>
                            <field name="default_value"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.dataset.join.key — вкладена list (всередині таблиці бленда) -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_dataset_join_key_list" model="ir.ui.view">
        <field name="name">td.bi.dataset.join.key.list</field>
        <field name="model">td.bi.dataset.join.key</field>
        <field name="arch" type="xml">
            <list string="Ключі зʼєднання" editable="bottom">
                <field name="left_field"/>
                <field name="right_field"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.dataset.join — form таблиці бленда (вкладені ключі)         -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_dataset_join_form" model="ir.ui.view">
        <field name="name">td.bi.dataset.join.form</field>
        <field name="model">td.bi.dataset.join</field>
        <field name="arch" type="xml">
            <form string="Таблиця бленда">
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="source_model_id"/>
                            <field name="source_dataset_id"/>
                            <field name="join_type"/>
                        </group>
                        <group>
                            <field name="table_domain"/>
                            <field name="table_date_field"/>
                            <field name="included_field_ids" widget="many2many_tags"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ключі зʼєднання" name="keys">
                            <field name="key_ids">
                                <list editable="bottom">
                                    <field name="left_field"/>
                                    <field name="right_field"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.dataset — list                                              -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_dataset_list" model="ir.ui.view">
        <field name="name">td.bi.dataset.list</field>
        <field name="model">td.bi.dataset</field>
        <field name="arch" type="xml">
            <list string="Датасети">
                <field name="name"/>
                <field name="mode"/>
                <field name="model_id"/>
                <field name="visibility"/>
                <field name="owner_id"/>
                <field name="version"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.dataset — search                                            -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_dataset_search" model="ir.ui.view">
        <field name="name">td.bi.dataset.search</field>
        <field name="model">td.bi.dataset</field>
        <field name="arch" type="xml">
            <search string="Пошук датасетів">
                <field name="name"/>
                <field name="model_id"/>
                <field name="owner_id"/>
                <filter string="Мої" name="my_datasets"
                        domain="[('owner_id', '=', uid)]"/>
                <filter string="Архівовані" name="inactive"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Модель Odoo" name="mode_model" domain="[('mode', '=', 'model')]"/>
                <filter string="Обʼєднання" name="mode_blend" domain="[('mode', '=', 'blend')]"/>
                <filter string="SQL" name="mode_sql" domain="[('mode', '=', 'sql')]"/>
                <group>
                    <filter string="Режим" name="group_mode" context="{'group_by': 'mode'}"/>
                    <filter string="Видимість" name="group_visibility" context="{'group_by': 'visibility'}"/>
                    <filter string="Власник" name="group_owner" context="{'group_by': 'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- td.bi.dataset — form (вкладки Поля/Бленд/Міри/Параметри)          -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="view_bi_dataset_form" model="ir.ui.view">
        <field name="name">td.bi.dataset.form</field>
        <field name="model">td.bi.dataset</field>
        <field name="arch" type="xml">
            <form string="Датасет">
                <sheet>
                    <widget name="web_ribbon" title="Архівовано" bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Назва датасету"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="mode"/>
                            <field name="model_id" invisible="mode != 'model'"
                                   required="mode == 'model'"/>
                            <field name="model_name" invisible="1"/>
                            <field name="domain" invisible="mode == 'sql'"/>
                            <field name="currency_strategy"/>
                            <field name="date_field_default"/>
                            <field name="fiscalyear_offset"/>
                        </group>
                        <group>
                            <field name="visibility"/>
                            <field name="group_ids" widget="many2many_tags"
                                   invisible="visibility != 'groups'"/>
                            <field name="company_ids" widget="many2many_tags"
                                   groups="base.group_multi_company"/>
                            <field name="owner_id"/>
                            <field name="cache_ttl"/>
                            <field name="row_limit"/>
                            <field name="version" readonly="1"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Поля" name="fields">
                            <field name="field_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="path"/>
                                    <field name="field_type"/>
                                    <field name="role"/>
                                    <field name="aggregator"/>
                                    <field name="is_formula"/>
                                    <field name="formula" invisible="not is_formula"/>
                                    <field name="currency_path"/>
                                    <field name="geo_role"/>
                                    <field name="visible"/>
                                </list>
                            </field>
                        </page>
                        <page string="Обʼєднання (бленд)" name="blend"
                              invisible="mode != 'blend'">
                            <field name="join_ids">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="source_model_id"/>
                                    <field name="source_dataset_id"/>
                                    <field name="join_type"/>
                                    <field name="table_domain"/>
                                </list>
                            </field>
                        </page>
                        <page string="Міри" name="measures">
                            <field name="measure_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="field_id"/>
                                    <field name="aggregator"/>
                                    <field name="expression"/>
                                    <field name="extra_domain"/>
                                    <field name="show_as"/>
                                    <field name="time_intelligence"/>
                                </list>
                            </field>
                        </page>
                        <page string="Параметри" name="parameters">
                            <field name="parameter_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="label"/>
                                    <field name="param_type"/>
                                    <field name="permitted"/>
                                    <field name="url_changeable"/>
                                </list>
                            </field>
                        </page>
                        <page string="SQL" name="sql" invisible="mode != 'sql'"
                              groups="td_bi_dashboard.group_bi_admin">
                            <field name="sql_query" placeholder="SELECT ... (тільки SELECT; record rules не діють)"/>
                            <field name="sql_field_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="field_type"/>
                                    <field name="role"/>
                                    <field name="aggregator"/>
                                </list>
                            </field>
                        </page>
                        <page string="Опис" name="description">
                            <field name="description" placeholder="Опис датасету для каталогу..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════════════ -->
    <!-- Дія вікна для датасетів                                           -->
    <!-- ════════════════════════════════════════════════════════════════ -->
    <record id="action_bi_dataset" model="ir.actions.act_window">
        <field name="name">BI: Датасети</field>
        <field name="res_model">td.bi.dataset</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bi_dataset_search"/>
        <field name="context">{'search_default_my_datasets': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Створіть перший датасет
            </p>
            <p>
                Датасет — джерело даних для дашборда: коренева модель Odoo,
                поля з глибини звʼязків, фільтри, міри та параметри.
            </p>
        </field>
    </record>

</odoo>
