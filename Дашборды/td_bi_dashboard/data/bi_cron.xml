<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Очистка простроченого кешу (~15 хв); видаляє td.bi.cache з expires_at у минулому (ВИМ-47) -->
        <record id="ir_cron_bi_clear_expired_cache" model="ir.cron">
            <field name="name">BI: Очистка простроченого кешу</field>
            <field name="model_id" ref="td_bi_dashboard.model_td_bi_cache"/>
            <field name="state">code</field>
            <field name="code">model._cron_clear_expired()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Доставка підписок за розкладом (daily/weekly/monthly/cron) — AC-33, AC-34 -->
        <record id="ir_cron_bi_run_subscriptions" model="ir.cron">
            <field name="name">BI: Доставка підписок дашбордів</field>
            <field name="model_id" ref="td_bi_dashboard.model_td_bi_subscription"/>
            <field name="state">code</field>
            <field name="code">model._cron_run_subscriptions()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Перевірка алертів за check_interval з троттлінгом hourly/daily — AC-35 -->
        <record id="ir_cron_bi_check_alerts" model="ir.cron">
            <field name="name">BI: Перевірка алертів за порогом</field>
            <field name="model_id" ref="td_bi_dashboard.model_td_bi_alert"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_alerts()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Оновлення матеріалізованих предагрегатів (REFRESH MATERIALIZED VIEW CONCURRENTLY) — AC-62 -->
        <record id="ir_cron_bi_refresh_materialization" model="ir.cron">
            <field name="name">BI: Оновлення матеріалізації</field>
            <field name="model_id" ref="td_bi_dashboard.model_td_bi_materialization"/>
            <field name="state">code</field>
            <field name="code">model._cron_refresh()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
